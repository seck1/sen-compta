# .env de PRODUCTION — copier en .env sur le VPS et remplir les vraies valeurs.
# NE JAMAIS committer le .env rempli (il est deja dans .gitignore).

APP_URL=https://sen-compta.com
APP_ENV=production

# Base de donnees (MySQL dans le conteneur docker -> host = "db")
DB_HOST=db
DB_NAME=cabinet_smc
DB_USER=cabinet_user
DB_PASS=CHANGER_mot_de_passe_fort
DB_ROOT_PASS=CHANGER_root_password_tres_fort

# Identite du cabinet (obligatoire pour conformite DGID / factures)
CABINET_NOM=Cabinet SMC
CABINET_QUALITE=Expert-Comptable
CABINET_NINEA=
CABINET_RCCM=
CABINET_ADRESSE=
CABINET_TEL=
CABINET_EMAIL=

# Token pour l'endpoint de backup (generer : openssl rand -hex 32)
BACKUP_TOKEN=

SESSION_LIFETIME=7200

# Cle API Anthropic (fonction Scan IA) — mettre la vraie cle ici, jamais dans le code
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
